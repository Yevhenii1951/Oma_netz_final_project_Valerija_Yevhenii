# ─── DATABASE ────────────────────────────────────
DATABASE_URL="postgresql://oma_user:oma_password@localhost:5432/oma_netz"

# ─── NEXTAUTH ────────────────────────────────────
AUTH_SECRET="your-super-secret-key-min-32-chars-here"
AUTH_URL="http://localhost:3000"

# ─── PUSHER (real-time chat) ─────────────────────
# Sign up free at https://pusher.com
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ─── GROQ AI (free tier) ─────────────────────────
# Sign up free at https://console.groq.com
GROQ_API_KEY="your-groq-api-key"

# ─── RESEND EMAIL (free tier) ────────────────────
# Sign up free at https://resend.com
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@oma-netz.de"

# ─── TELEGRAM BOT ────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# ─── OPTIONAL: App URL ───────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
